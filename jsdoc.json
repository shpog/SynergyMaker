{
    "plugins": [],
    "recurseDepth": 10,
    "source": {
        "include": [
            "src"
        ],
        "includePattern": ".+\\.js$",
        "excludePattern": "(node_modules|public)"
    },
    "templates": {
        "cleverLinks": false,
        "monospaceLinks": false,
        "default": {
            "outputSourceFiles": true,
            "staticFiles": {
                "include": []
            }
        }
    },
    "opts": {
        "destination": "./docs",
        "recurse": true,
        "readme": "./README.md"
    }
}
